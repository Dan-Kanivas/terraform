# Ignore Terraform working directories everywhere
**/.terraform/

# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Terraform variable files containing secrets
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

**/.terraform.lock.hcl
**/elastic key pairs.pem

# Terraform lock file (optional depending on workflow)
# .terraform.lock.hcl